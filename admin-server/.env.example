PORT=9000
CORS_ORIGIN=http://localhost:5174
FIREBASE_SERVICE_ACCOUNT_PATH=../../Server/config/firebase-service-account.json

# Admin Email Whitelist (comma-separated)
ADMIN_EMAILS=admin@example.com,another.admin@example.com

# Gemini API (for card comparison and automated reviews)
GEMINI_API_KEY=your_gemini_api_key

# Cloudflare Browser Rendering (for automated card review scraping)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Jina Reader (optional - works without key at 20 RPM, with key gives 10M tokens + 100 RPM)
JINA_API_KEY=your_jina_api_key
